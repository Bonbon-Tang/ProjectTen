# CPU Test Runner Dockerfile
FROM python:3.12-slim

WORKDIR /app

# 复制依赖
COPY cpu-test-runner/requirements.txt .

# 安装依赖
RUN pip install --no-cache-dir -r requirements.txt

# 复制代码
COPY cpu-test-runner/ ./

# 创建报告目录
RUN mkdir -p backend/data/cpu_test_reports

# 默认命令
CMD ["python", "runner.py", "--help"]
